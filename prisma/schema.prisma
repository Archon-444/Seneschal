// Seneschal — Prisma schema v1.0
// Derived from spec v2 (§6) + v2.1 patch (P2,P3,P5,P6,P8,P9,P10) + v2.2 decisions (D12,D13,D15)
// Conventions: UUID PKs, workspaceId on every scoped table, archive (not delete),
// EvidenceEvent / AuditEvent / DocumentAccessLog / NotificationMessage are INSERT-ONLY (enforced in app layer + DB grants).
// Stage tags: [1A] build now · [1B] schema now, UI later · [S2] deferred, do not migrate yet (commented at end).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Identity & access [1A]

model Workspace {
  id          String   @id @default(uuid())
  name        String
  type        WorkspaceType
  createdAt   DateTime @default(now())
  suspendedAt DateTime?            // F-Admin §3.2: temporary platform suspend — blocks the interactive door (authz) only; the daily sweep keeps running (runner.ts). Distinct from archive (terminal).
  archivedAt  DateTime?
  memberships Membership[]
  @@index([type])
}

enum WorkspaceType {
  OWNER
  FIDUCIARY
  OPERATOR
  INTERNAL
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  phone           String?  @unique
  name            String
  locale          String   @default("en")
  isPlatformAdmin Boolean  @default(false)   // Seneschal operator: lifecycle/billing/aggregate stats only, NEVER customer data (F-Admin §3). Holds zero Membership rows.
  createdAt       DateTime @default(now())
  memberships     Membership[]
}

model Membership {
  id                String  @id @default(uuid())
  workspaceId       String
  userId            String
  role              Role
  clientPrincipalId String?          // required when role = CLIENT_VIEWER (scopes to one client)
  subjectContactId  String?          // required when role = TENANT | LANDLORD (scopes to one Contact)
  createdAt         DateTime @default(now())
  revokedAt         DateTime?
  workspace         Workspace @relation(fields: [workspaceId], references: [id])
  user              User      @relation(fields: [userId], references: [id])
  grants            MembershipGrant[]
  clientAssignments ClientAssignment[]   // F-Admin (D3): a MANAGING_AGENT's delegate scope (was assignedClientIds[])
  @@unique([workspaceId, userId, role])
  @@index([workspaceId])
  @@index([userId])
}

// F-Admin (D1): audited per-membership capability grants — the "who granted whom, when"
// a fiduciary product needs. Effective caps = roleMap(role) ∪ expand(live grants).
model MembershipGrant {
  id           String     @id @default(uuid())
  membershipId String
  bundle       Bundle
  grantedById  String
  grantedAt    DateTime   @default(now())
  revokedAt    DateTime?
  revokedById  String?
  membership   Membership @relation(fields: [membershipId], references: [id])
  @@index([membershipId])
  // Live-uniqueness — at most ONE non-revoked grant per (membership, bundle) — is a raw
  // PARTIAL unique index added in the migration (WHERE "revokedAt" IS NULL). Prisma can't
  // express a filtered unique and won't drift on it (mirrors RiskFlag_active_unique). A
  // plain @@unique would collide on re-grant-after-revoke.
}

// F-Admin (D3): the people×clients assignment grid — the delegate's scope, as an AUDITED
// join (was Membership.assignedClientIds[]). An assignment is a delegation ACT, not state, so
// provenance (assignedById/assignedAt, revokedAt/revokedById) is inseparable from the row.
// resolveClientScopeIds reads the LIVE rows; there is no cached array to drift.
model ClientAssignment {
  id                String     @id @default(uuid())
  workspaceId       String
  membershipId      String                  // the delegate (MANAGING_AGENT)
  clientPrincipalId String
  assignedById      String?                 // null = backfilled/system: provenance is pre-audit, never fabricated
  assignedAt        DateTime   @default(now())
  backfilledAt      DateTime?                // set ONLY by the array→table backfill; flags "we don't know who originally granted"
  revokedAt         DateTime?
  revokedById       String?
  membership        Membership @relation(fields: [membershipId], references: [id])
  @@index([workspaceId, membershipId])
  // Live-uniqueness — one non-revoked assignment per (membership, client) — is a raw PARTIAL
  // unique index in the migration (WHERE "revokedAt" IS NULL). Prisma can't express a filtered
  // unique; a plain @@unique would collide the instant a revoked client is re-assigned.
}

enum Role {
  WORKSPACE_ADMIN
  MANAGER
  FIDUCIARY
  ORG_ADMIN         // F-Admin: people/config power, ZERO data caps (onboards staff, wires delegate assignments, cannot open a tenancy)
  CLIENT_VIEWER
  AGENT
  MANAGING_AGENT    // execution delegate: read + broad write, confined to its live ClientAssignment rows
  LICENSED_PARTNER
  VENDOR
  AUDITOR
  LANDLORD          // self-service supply-side persona; scoped to one Contact via Membership.subjectContactId
  TENANT            // self-service demand-side persona; scoped to one Contact via Membership.subjectContactId
}

// F-Admin (D1): capability bundles, unioned OVER the role map (effective = roleMap ∪ grants).
// IMPORTANT — only ORG_ADMIN is actually honored as a grant (capabilities.GRANT_HONORED_BUNDLES).
// PRINCIPAL/DELEGATE/CLIENT_VIEWER are RESERVED but NOT grantable: a grant carries no scope, and
// scope(ctx) narrows by ROLE only, so honoring a DATA bundle would confer caps with a workspace-
// wide read (a leak). Those data shapes come from the BASE ROLE — PRINCIPAL via seat-zero
// (WORKSPACE_ADMIN), DELEGATE via a MANAGING_AGENT membership + the assignment grid. Do not honor
// a data bundle without first teaching scope(ctx) to narrow grant-derived data caps.
enum Bundle {
  PRINCIPAL
  ORG_ADMIN
  DELEGATE
  CLIENT_VIEWER
}

// F-Admin §3.4 / §4.1: seat-zero (platform-issued) and in-org member invites. Token-hash
// discipline reused from SecureLink — only the hash is stored, the raw token is returned once.
model WorkspaceInvite {
  id              String    @id @default(uuid())
  workspaceId     String
  email           String
  intendedBundles Bundle[]  @default([])
  tokenHash       String    @unique
  invitedById     String?               // null when platform-issued seat-zero
  platformIssued  Boolean   @default(false)
  expiresAt       DateTime
  acceptedAt      DateTime?
  acceptedUserId  String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  @@index([workspaceId])
  @@index([email])
}
// Platform admin is NOT a membership role: the Seneschal operator plane runs under PlatformAdminContext
// (User.isPlatformAdmin), reaches lifecycle/billing/aggregate stats only, and holds zero Membership rows (F-Admin §3.1).

// ───────────────────────────── Core records [1A]

model ClientPrincipal {
  id          String   @id @default(uuid())
  workspaceId String
  displayName String
  contactInfo Json?
  notes       String?
  createdAt   DateTime @default(now())
  archivedAt  DateTime?            // D12: archive lifecycle, never hard delete
  @@index([workspaceId])
}

model Contact {
  id          String      @id @default(uuid())
  workspaceId String
  kind        ContactKind
  name        String
  phone       String?
  email       String?
  company     String?
  // Ejari party identity (optional) — captured during onboarding from the
  // Unified Tenancy Contract; licenseNo/Authority used when the party is a company.
  emiratesId          String?
  nationality         String?
  licenseNo           String?
  licensingAuthority  String?
  notes       String?
  // Landlord verification (1B #2): the workspace confirms an OWNER's identity/
  // ownership. State is denormalized here; the LANDLORD_VERIFIED evidence event is
  // the append-only audit trail (revocation is a new event).
  verifiedAt  DateTime?
  verifiedById String?
  createdAt   DateTime    @default(now())
  archivedAt  DateTime?
  @@index([workspaceId, kind])
}

enum ContactKind {
  OWNER
  TENANT
  AGENT
  VENDOR
  CONTRACTOR
  CLIENT
  PARTNER
  BUILDING_MANAGEMENT
  ACCOUNTANT
  LAWYER
  OTHER
}

model Property {
  id                String   @id @default(uuid())
  workspaceId       String
  clientPrincipalId String?
  ownerContactId    String?          // Contact — the landlord/owner; LANDLORD persona scopes to owned properties (incl. vacant)
  community         String
  building          String?
  unitNo            String?
  emirate           String   @default("Dubai")
  propertyType      String?          // free text: "Apartment", "2 Bed Villa + Maid"...
  bedrooms          Int?
  sizeSqft          Int?
  // Ejari asset identifiers (optional) — captured during onboarding
  usage             String?          // Residential | Commercial | Industrial
  plotNo            String?
  makaniNo          String?
  dewaPremiseNo     String?
  sizeSqm           Decimal?  @db.Decimal(10, 2)
  assignedAgentId   String?          // Contact
  serviceChargeInfo Json?
  riskStatus        String?
  notes             String?
  createdAt         DateTime @default(now())
  archivedAt        DateTime?
  tenancies         Tenancy[]
  listings          Listing[]
  @@index([workspaceId, clientPrincipalId])
}
// TODO [later]: optional Unit entity under Property for multi-unit assets.

model Tenancy {
  id               String        @id @default(uuid())
  workspaceId      String
  propertyId       String
  landlordContactId String?
  tenantContactId  String?
  ejariNo          String?
  startDate        DateTime      // date-only semantics; compute in Asia/Dubai, store UTC midnight
  endDate          DateTime
  annualRent       Decimal       @db.Decimal(12, 2)
  depositAmount    Decimal?      @db.Decimal(12, 2)
  paymentTermsNote String?
  noticePeriodDays Int           @default(90)   // contract override supported (fixture: 60-day clause)
  noticeGateAt     DateTime?     // cached; authoritative rows live in Deadline
  status           TenancyStatus @default(ACTIVE)
  source           RecordSource  @default(MANUAL)
  contractDocId    String?
  createdAt        DateTime      @default(now())
  archivedAt       DateTime?
  /** PR6: lineage to the predecessor tenancy when this row was minted by
   *  mintRenewedTenancy. NULL on original (non-renewal) tenancies. @unique so a
   *  predecessor can have at most one successor — the DB backstop against a
   *  concurrent double-mint (see mintRenewedTenancy). Postgres allows many NULLs
   *  under a unique index, so original tenancies are unaffected. */
  renewsFromTenancyId String?       @unique
  renewsFrom       Tenancy?      @relation("TenancyRenewal", fields: [renewsFromTenancyId], references: [id])
  successor        Tenancy?      @relation("TenancyRenewal")
  property         Property      @relation(fields: [propertyId], references: [id])
  contractDoc      Document?     @relation("TenancyContract", fields: [contractDocId], references: [id])
  paymentItems     PaymentItem[]
  deadlines        Deadline[]
  @@index([workspaceId, propertyId])
  @@index([workspaceId, endDate])
}

enum TenancyStatus {
  ACTIVE
  RENEWAL_DUE
  NOTICE_SERVED
  NEGOTIATING
  RENEWED
  ENDING
  DISPUTED
  ARCHIVED
}
enum RecordSource {
  OCR
  EXCEL
  MANUAL
}

// ───────────────────────────── Listings [1B] — landlord supply side

// ───────────────────────────────────────────────────────────────────────────
// ARCHIVED — out of product scope (see QUARANTINE.md). The marketplace/passport
// models below (Listing, TenantPassport, Enquiry, Viewing, ContractPack) back
// killed concepts, not roadmap. They are kept fail-closed and unreachable, not
// maintained; core renewal/evidence code must not depend on them.
// ───────────────────────────────────────────────────────────────────────────
//
// A landlord's marketing record for a (typically vacant) owned unit. Scoped to
// the owning Property, so the LANDLORD persona reaches it through the same
// owned-property id-set as everything else (services/contactScope.ts). The
// readiness score is a deterministic calculator (calculators/listingReadiness.ts)
// whose { rule, version, inputs } breakdown is cached in `readiness`.
model Listing {
  id             String        @id @default(uuid())
  workspaceId    String
  propertyId     String
  status         ListingStatus @default(DRAFT)
  headline       String?
  askingRent     Decimal?      @db.Decimal(12, 2)
  availableFrom  DateTime?     // date-only semantics; store UTC midnight via toUtcDateOnly
  furnished      Boolean?
  description    String?
  permitRef      String?       // RERA/Trakheesi (Madmoun) permit — expiry/alerts wiring lands in 1B issue #3
  permitExpiry   DateTime?     // date-only
  readinessScore Int?          // cached 0..100; calculators/listingReadiness.ts is authoritative
  readiness      Json?         // { rule, version, score, checks: [{ key, label, ok, weight }] }
  publishedAt    DateTime?
  createdById    String
  createdAt      DateTime      @default(now())
  archivedAt     DateTime?
  property       Property      @relation(fields: [propertyId], references: [id])
  @@index([workspaceId, status])
  @@index([workspaceId, propertyId])
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ───────────────────────────── Tenant passport [1C] — demand side

// A tenant's reusable rental profile, scoped to ONE Contact (the TENANT persona's
// subjectContactId). Supporting documents attach as scope-polymorphic Documents
// (scopeType TENANT_PASSPORT, scopeId = passport id). Sharing with a landlord/agent
// is a consent-gated secure link (PASSPORT_SHARE).
model TenantPassport {
  id            String         @id @default(uuid())
  workspaceId   String
  contactId     String         // the TENANT persona's Contact — one passport per contact
  status        PassportStatus @default(DRAFT)
  employer      String?
  jobTitle      String?
  monthlyIncome Decimal?       @db.Decimal(12, 2)
  nationality   String?
  householdSize Int?
  moveInBy      DateTime?      // date-only; store UTC midnight via toUtcDateOnly
  summary       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@unique([workspaceId, contactId])
}

enum PassportStatus {
  DRAFT
  READY
}

// A prospective-tenant enquiry against a published listing (1C #8), captured from
// the public listing link — no account. Notifies the workspace overseers.
model Enquiry {
  id           String        @id @default(uuid())
  workspaceId  String
  listingId    String?
  propertyId   String?
  name         String
  email        String?
  phone        String?
  message      String?
  status       EnquiryStatus @default(NEW)
  source       String?       // e.g. "LISTING_LINK"
  secureLinkId String?
  createdAt    DateTime      @default(now())
  @@index([workspaceId, status])
}

enum EnquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

// A scheduled property viewing for a prospective tenant (2A #10), usually arising
// from an Enquiry on a listing. scheduledAt is a real timestamp (a time slot), not
// a date-only contract date.
model Viewing {
  id           String        @id @default(uuid())
  workspaceId  String
  propertyId   String
  listingId    String?
  enquiryId    String?
  contactId    String?       // prospective tenant, if a Contact exists
  prospectName String?       // free text when there is no Contact yet
  scheduledAt  DateTime
  status       ViewingStatus @default(REQUESTED)
  notes        String?
  createdById  String?
  createdAt    DateTime      @default(now())
  @@index([workspaceId, status])
  @@index([workspaceId, scheduledAt])
}

enum ViewingStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Contract pack (2A #12) — a generated PDF of the agreed terms from an accepted
// new-tenancy Offer, stored as a Document (PROPERTY-scoped so owner + operator can
// read it). The e-sign reference (#13) is captured here, not in a separate table.
model ContractPack {
  id          String             @id @default(uuid())
  workspaceId String
  offerId     String
  listingId   String?
  propertyId  String
  documentId  String             // the generated PDF Document
  status      ContractPackStatus @default(GENERATED)
  eSignRef    String?            // external e-sign provider reference (#13)
  sentAt      DateTime?
  signedAt    DateTime?
  createdById String?
  createdAt   DateTime           @default(now())
  @@index([workspaceId, offerId])
}

enum ContractPackStatus {
  GENERATED
  SENT_FOR_SIGNATURE
  SIGNED
}

// Move-in handover (2A #14) — condition record for a tenancy, with a photo vault
// (PROPERTY-scoped Documents) and a DUAL acknowledgement: both landlord and tenant
// confirm the recorded condition. Completed only when both have acknowledged.
model MoveIn {
  id            String       @id @default(uuid())
  workspaceId   String
  tenancyId     String
  propertyId    String
  status        MoveInStatus @default(PENDING)
  landlordAckAt DateTime?
  tenantAckAt   DateTime?
  notes         String?
  createdById   String?
  createdAt     DateTime     @default(now())
  @@index([workspaceId, tenancyId])
}

enum MoveInStatus {
  PENDING
  PARTIALLY_ACKNOWLEDGED
  COMPLETED
}

// ───────────────────────────── Deadlines & calendar [1A]

model Deadline {
  id           String       @id @default(uuid())
  workspaceId  String
  tenancyId    String?
  propertyId   String?
  kind         DeadlineKind
  dueAt        DateTime
  status       DeadlineStatus @default(OPEN)
  computedFrom Json?          // { rule: "notice_gate_v1", inputs: {...} } — calculator version citation
  createdAt    DateTime     @default(now())
  tenancy      Tenancy?     @relation(fields: [tenancyId], references: [id])
  @@index([workspaceId, dueAt])
  @@index([workspaceId, status, kind])
}

enum DeadlineKind {
  NOTICE_GATE
  CONTRACT_EXPIRY
  RENEWAL_DATE
  CHEQUE_DUE
  CHEQUE_FOLLOWUP
  SERVICE_CHARGE_DUE
  INSURANCE_EXPIRY
  DOCUMENT_EXPIRY
  APPROVAL_DUE
  TENANT_RESPONSE_DUE
  EJARI_RENEWAL
  PERMIT_EXPIRY
  CUSTOM
}
enum DeadlineStatus {
  OPEN
  DONE
  MISSED
  CANCELLED
}

// ───────────────────────────── Payments register [1A] — record-keeping only, no custody

model PaymentItem {
  id            String        @id @default(uuid())
  workspaceId   String
  tenancyId     String
  seq           Int
  dueDate       DateTime
  amount        Decimal       @db.Decimal(12, 2)
  instrument    Instrument    @default(CHEQUE)
  chequeNo      String?
  bank          String?
  status        PaymentStatus @default(SCHEDULED)
  proofDocId    String?
  confirmedById String?
  notes         String?
  createdAt     DateTime      @default(now())
  tenancy       Tenancy       @relation(fields: [tenancyId], references: [id])
  @@unique([tenancyId, seq])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, status])
}

enum Instrument {
  CHEQUE
  TRANSFER
  DDS
}
enum PaymentStatus {
  SCHEDULED
  REQUESTED
  RECEIVED
  DEPOSITED
  CLEARED
  LATE
  BOUNCED
  CANCELLED
}

// ───────────────────────────── Documents [1A]

model Document {
  id           String   @id @default(uuid())
  workspaceId  String
  scopeType    ScopeType
  scopeId      String?
  kind         DocumentKind
  fileName     String
  mime         String
  sizeBytes    Int
  storageKey   String   @unique
  sha256       String                 // integrity hash at ingest
  uploadedById String?                // null when via secure link
  secureLinkId String?
  createdAt    DateTime @default(now())
  archivedAt   DateTime?
  contractTenancies Tenancy[] @relation("TenancyContract") // H3: concrete FK back-ref
  @@index([workspaceId, scopeType, scopeId])
  @@index([sha256])
}

enum ScopeType {
  WORKSPACE
  CLIENT
  PROPERTY
  TENANCY
  PAYMENT_ITEM
  PROOF_REQUEST
  MAINTENANCE_CASE
  IMPORT_BATCH
  REPORT
  TASK
  RENEWAL_CASE
  OFFER
  LISTING
  TENANT_PASSPORT
}
enum DocumentKind {
  TENANCY_CONTRACT
  EJARI_CERTIFICATE
  TITLE_DEED
  ID_DOCUMENT
  CHEQUE_IMAGE
  RECEIPT
  BANK_CONFIRMATION
  INVOICE
  QUOTATION
  MAINTENANCE_PHOTO
  HANDOVER_REPORT
  NOTICE
  ACKNOWLEDGEMENT
  APPROVAL
  SERVICE_CHARGE_STATEMENT
  POA_NOC
  OTHER
}

model DocumentAccessLog {            // P6: dedicated, insert-only — never buried in AuditEvent
  id           String   @id @default(uuid())
  workspaceId  String
  documentId   String
  actorUserId  String?
  secureLinkId String?
  partnerOrgId String?
  action       DocAccessAction
  ip           String?
  device       String?
  createdAt    DateTime @default(now())
  @@index([workspaceId, documentId])
  @@index([documentId, createdAt])
}

enum DocAccessAction {
  VIEWED
  DOWNLOADED
  UPLOADED
  DELETED
  EXPORTED
  SHARED
}

// ───────────────────────────── Intake: OCR-first [1A thin] + Excel fallback [1A]

model ExtractionJob {                // D13: thin pipeline in 1A — upload → extract → review → commit
  id           String   @id @default(uuid())
  workspaceId  String
  documentId   String
  status       ExtractionStatus @default(PENDING)
  model        String?
  rawOutput    Json?                  // proposed fields
  confidence   Json?                  // per-field confidence
  reviewedById String?
  reviewedAt   DateTime?
  importBatchId String?               // commits flow through the same batch machinery as Excel
  createdAt    DateTime @default(now())
  @@index([workspaceId, status])
}

enum ExtractionStatus {
  PENDING
  EXTRACTED
  REVIEWING
  COMMITTED
  REJECTED
  FAILED
}

model ImportBatch {                  // P8: nothing writes to trusted records until commit
  id          String      @id @default(uuid())
  workspaceId String
  source      ImportSource
  fileDocId   String?
  mappingJson Json?
  status      ImportStatus @default(UPLOADED)
  reviewerId  String?
  committedAt DateTime?
  rolledBackAt DateTime?
  createdAt   DateTime    @default(now())
  rows        ImportRow[]
  @@index([workspaceId, status])
}

enum ImportSource {
  EXCEL
  DOCUMENTS
}
enum ImportStatus {
  UPLOADED
  MAPPED
  REVIEWING
  COMMITTED
  ROLLED_BACK
}

model ImportRow {
  id                String        @id @default(uuid())
  workspaceId       String
  batchId           String
  rawJson           Json
  mappedJson        Json?
  status            ImportRowStatus @default(PENDING)
  conflictReason    String?        // duplicate ejariNo, overlapping tenancy dates — blocks ROW not batch
  createdRecordRefs Json?          // [{type, id}] for rollback-as-archive
  batch             ImportBatch   @relation(fields: [batchId], references: [id])
  @@index([batchId, status])
}

enum ImportRowStatus {
  PENDING
  ACCEPTED
  REJECTED
  CONFLICT
}

// ───────────────────────────── Proof requests & secure links [1A] — the core verb

model ProofRequest {
  id                String      @id @default(uuid())
  workspaceId       String
  scopeType         ScopeType
  scopeId           String?
  title             String
  requiredEvidence  String
  assignedContactId String
  dueAt             DateTime?
  status            ProofStatus @default(OPEN)
  decisionById      String?
  decisionAt        DateTime?
  decisionNote      String?
  createdById       String
  createdAt         DateTime    @default(now())
  @@index([workspaceId, status])
  @@index([workspaceId, assignedContactId])
}

enum ProofStatus {
  OPEN
  SENT
  WAITING_PROOF
  SUBMITTED
  APPROVED
  REJECTED
  OVERDUE
  CLOSED
}

model SecureLink {
  id          String        @id @default(uuid())
  workspaceId String
  purpose     LinkPurpose
  scopeType   ScopeType
  scopeId     String
  contactId   String?
  tokenHash   String        @unique   // NEVER store raw token
  expiresAt   DateTime
  maxUses     Int?
  useCount    Int           @default(0)
  revokedAt   DateTime?
  createdById String
  createdAt   DateTime      @default(now())
  @@index([workspaceId, purpose])
}

enum LinkPurpose {
  PROOF_UPLOAD
  DOCUMENT_SHARE
  APPROVAL
  TENANT_OFFER
  LISTING_VIEW
  PASSPORT_SHARE
} // TENANT_OFFER activates Stage 2; LISTING_VIEW + PASSPORT_SHARE are 1B/1C public pages

model ConsentRecord {                // P5
  id            String        @id @default(uuid())
  workspaceId   String
  // Exactly one subject: a Contact (tenant/landlord) or a workspace User.
  // Both are append-only — a revocation sets revokedAt, never deletes.
  contactId     String?
  userId        String?
  purpose       ConsentPurpose
  source        ConsentSource
  noticeVersion String
  secureLinkId  String?
  grantedAt     DateTime      @default(now())
  revokedAt     DateTime?
  @@index([workspaceId, contactId])
  @@index([workspaceId, userId])
}

enum ConsentPurpose {
  PROCESSING
  MESSAGING
  DOCUMENT_STORAGE
  LINK_INTERACTION
  PASSPORT_SHARING
}
enum ConsentSource {
  SECURE_LINK
  WHATSAPP_OPTIN
  FORM
  CONTRACT
}

// ───────────────────────────── Tasks & workflow instances [1A minimal]

model Task {
  id          String     @id @default(uuid())
  workspaceId String
  scopeType   ScopeType
  scopeId     String?
  title       String
  assigneeUserId String?
  assigneeContactId String?
  dueAt       DateTime?
  priority    Int        @default(0)
  status      TaskStatus @default(OPEN)
  proofDocId  String?
  workflowInstanceId String?
  createdAt   DateTime   @default(now())
  @@index([workspaceId, status])
}

enum TaskStatus {
  OPEN
