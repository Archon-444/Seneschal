model RiskFlag {                     // P10: deterministic rules raise; agent may only PROPOSE
  id          String       @id @default(uuid())
  workspaceId String
  scopeType   ScopeType
  scopeId     String
  code        RiskCode
  severity    Severity
  raisedBy    RaisedBy
  ruleVersion String?
  status      FlagStatus   @default(OPEN)
  raisedAt    DateTime     @default(now())
  clearedAt   DateTime?
  clearedById String?
  @@index([workspaceId, status])
  @@index([workspaceId, scopeType, scopeId, code]) // active-flag lookup (raise/clear/acknowledge)
  // H2: at most ONE active (OPEN|ACKNOWLEDGED) flag per code per scope is enforced
  // by a partial unique index added via raw SQL in the migration — Prisma can't
  // express a filtered unique index. CLEARED rows are history and may repeat, so
  // status is NOT part of a full unique key (that forced a deleteMany workaround).
  // Prisma does not model filtered indexes, so it neither manages nor drifts on
  // this raw index — it survives `migrate dev` (verified: a no-op migration is
  // generated, not a DROP). See prisma/migrations/*_riskflag_partial_unique.
}

