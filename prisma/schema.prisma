model AuditEvent {                   // security/admin log; insert-only; hash chain in v1.1 (D6)
  id           String   @id @default(uuid())
  workspaceId  String?
  actorType    ActorType
  actorId      String?
  onBehalfOfId String?
  verb         String                // workspace.update, membership.create, securelink.revoke, import.rollback...
