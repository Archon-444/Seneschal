// ───────────────────────────── Renewals — decision support (Stage 2, now active)
// The Renewal Risk Desk: a captured rent-index figure + the Decree 43 lawful
// position drive renewal decisions. RenewalCase tracks the workflow per tenancy;
// RentIndexCapture is the manually-captured DLD reference (append-only, latest wins).
// EvidenceType already reserves INDEX_CAPTURED / RENEWAL_ASSESSMENT_CREATED / OFFER_*.

model RentIndexCapture {
  id            String   @id @default(uuid())
  workspaceId   String
  tenancyId     String
  propertyId    String
  marketRentAvg Decimal  @db.Decimal(12, 2)   // index average market rent (manual capture)
  source        String   @default("DLD Smart Rental Index")
  // PR6 Stage-2 additions. The computed fields (gapPct/permittedPct/permittedNewRentMax)
  // are NULLABLE *on purpose* — a backfilled row from before this PR has no honest
  // contemporaneous assessment and must NOT be back-filled by recomputing
  // decree43() against a reconstructed historical rent (that would write a
  // present-day figure onto a row dated months ago, indistinguishable from a real
  // capture-time assessment — a direct violation of provenance). New captures
  // populate all three at capture time; old rows keep NULLs and a sourceRef set
  // to MANUAL_CONCIERGE.
  indexSource         IndexSource?
  gapPct              Decimal?     @db.Decimal(5, 4)
  permittedPct        Int?
  permittedNewRentMax Decimal?     @db.Decimal(12, 2)
  calculatorVersion   String?
  comparableBasis     Json?
  sourceRef           Json?
  /** Set on rows backfilled by the migration (NULL on contemporaneous captures);
   *  the UI must render backfilled rows distinctly. */
  backfilledAt        DateTime?
  capturedAt    DateTime                       // when the figure was read from the official source
  capturedById  String?
  note          String?
  createdAt     DateTime @default(now())
  @@index([workspaceId, tenancyId])
}

enum IndexSource {
  SMART_RENTAL_INDEX_2025
  RERA_INDEX_LEGACY
  MANUAL_CONCIERGE
}

// A captured index figure reusable across units in a community (optionally a
// specific building), so a tenancy without its own capture can fall back to it.
// Append-only; latest capturedAt wins; building-specific is preferred over
// community-wide. Resolution lives in resolveEffectiveIndex (renewals.ts).
model RentIndexBenchmark {
  id            String   @id @default(uuid())
  workspaceId   String
  community     String
  building      String?
  marketRentAvg Decimal  @db.Decimal(12, 2)
  source        String   @default("DLD Smart Rental Index")
  capturedAt    DateTime
  capturedById  String?
  note          String?
  createdAt     DateTime @default(now())
  @@index([workspaceId, community, building])
}

model RenewalCase {
  id                  String        @id @default(uuid())
  workspaceId         String
  tenancyId           String
  propertyId          String
  status              RenewalStatus @default(ASSESSING)
  currentRentSnapshot Decimal       @db.Decimal(12, 2)  // rent at the time the case opened
  noticeGateAt        DateTime?                          // mirror of the NOTICE_GATE deadline
  expiresAt           DateTime                           // contract end
  renewalDate         DateTime                           // first day of the next term
  noticeServedAt      DateTime?                          // when the change notice was served
  noticeDocId         String?                            // Document holding the served notice
  decidedOfferId      String?                            // the accepted Offer
  // PR6 Stage-2 additions.
  /** The successor tenancy minted by mintRenewedTenancy (1:1 with this case). */
  renewedTenancyId    String?       @unique
  indexCaptureId      String?                            // the IndexCapture this case quotes
  proposedRent        Decimal?      @db.Decimal(12, 2)   // landlord's proposed new annual rent
  proposedStartDate   DateTime?
  proposedEndDate     DateTime?
  currentNoticeId     String?                            // active Notice driving the timeline
  currentOfferId      String?                            // active Offer under negotiation
  archivedAt          DateTime?
  createdById         String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  @@index([workspaceId, status])
  @@index([workspaceId, tenancyId])
}

// Versioned renewal terms — landlord proposals and tenant counters live as Offers
// on a RenewalCase. Each new figure supersedes the prior open one; history is kept.
model Offer {
  id              String      @id @default(uuid())
  workspaceId     String
  renewalCaseId   String?                           // null for a new-tenancy offer (2A #11)
  tenancyId       String?                           // null until a tenancy exists
  listingId       String?                           // set for a new-tenancy offer on a listing
  prospectContactId String?                         // the prospective tenant, when known
  version         Int
  party           OfferParty
  annualRent      Decimal     @db.Decimal(12, 2)
  paymentSchedule String                            // e.g. "4 cheques"
  paymentMethod   String?
  termMonths      Int?
  startDate       DateTime?
  note            String?
  status          OfferStatus @default(SENT)
  createdById     String?
  viaSecureLinkId String?                           // set when a tenant responds via secure link
  // PR6 Stage-2 additions. The snapshot is the permittedNewRentMax this offer was
  // measured against at the moment it was sent; it does NOT auto-update if a
  // later capture changes the ceiling. That's the whole point: an offer's
  // compliance posture has to be reproducible from the row alone.
  permittedMaxSnapshot  Decimal?  @db.Decimal(12, 2)
  // PR-pilot: the index capture this offer was assessed against, frozen at send
  // time. indexCitation is a self-contained snapshot bundle (captureId, source,
  // indexSource, capturedAt, calculatorVersion, comparableBasis, marketRentAvg,
  // permittedNewRentMax, provisional) so the tenant-facing comparison is
  // reproducible from the offer row alone — never re-derived from the latest live
  // capture. See proposeOffer / getOfferForLink.
  indexCaptureId        String?
  indexCitation         Json?
  responseDueDeadlineId String?
  proposedStartDate     DateTime?
  proposedEndDate       DateTime?
  createdAt       DateTime    @default(now())
  @@unique([renewalCaseId, version])
  @@index([workspaceId, renewalCaseId])
}

enum OfferParty {
  LANDLORD
  TENANT
}

enum OfferStatus {
  SENT
  COUNTERED
  ACCEPTED
  SUPERSEDED
  WITHDRAWN
}

// PR6 (Stage-2): the landlord's change/renewal notice. Previously implicit
// (a NOTICE_SERVED evidence row + RenewalCase.noticeServedAt/noticeDocId);
// promoted to a standalone row so the GENERATED → APPROVED → SERVED transitions
// and the served-by-which-method metadata are first-class. Each transition emits
// its own evidence row at its own moment (Notice service in PR6b enforces this).
model Notice {
  id              String       @id @default(uuid())
  workspaceId     String
  renewalCaseId   String
  kind            NoticeKind
  status          NoticeStatus @default(GENERATED)
  generatedAt     DateTime     @default(now())
  approvedAt      DateTime?
  approvedById    String?
  servedAt        DateTime?
  servedById      String?
  serviceMethod   ServiceMethod?
  serviceRef      String?                            // e.g. courier tracking id / inbox ref
  docId           String?                            // the served Notice document
  // PR-pilot: an explicit manual-attestation record is one of the three accepted
  // proofs of service (alongside serviceRef and docId). A notice may only reach
  // SERVED with at least one of them; without any it rests at
  // SERVICE_RECORDED_PENDING_EVIDENCE (see serveNoticeFormal / confirmNoticeService).
  attestation     String?                            // signed manual attestation text
  attestedById    String?
  attestedAt      DateTime?
  templateCode    String?                            // for compliance-copy audit (PR6c)
  templateVersion String?
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  @@index([workspaceId, renewalCaseId])
  @@index([workspaceId, status])
}

enum NoticeKind {
  RENEWAL_CHANGE
  NON_RENEWAL
}

enum NoticeStatus {
  GENERATED
  APPROVED
  // Service intent has been recorded but no proof (delivery reference, uploaded
  // document, or signed attestation) is attached yet. NOT a served notice — the
  // case/tenancy do not advance and no NOTICE_SERVED evidence is emitted.
  SERVICE_RECORDED_PENDING_EVIDENCE
  SERVED
  WITHDRAWN
}

enum ServiceMethod {
  EMAIL
  COURIER
  IN_PERSON
  REGISTERED_POST
  OTHER
}

enum RenewalStatus {
  ASSESSING
  NOTICE_DUE
  NOTICE_SERVED
  NEGOTIATING
  AGREED
  RENEWED
  DECLINED
  LAPSED
}

// ───────────────────────────── Stage 2 — DO NOT MIGRATE YET
// Offer, Notice, PartnerOrg per spec v2 §6 (Offer arrives in the negotiation PR).
// EvidenceType and LinkPurpose already reserve their values so Stage 2 adds tables without enum churn.

// ───────────────────────────── Auth [1A — ADDITION to schema v1.0]
// Reason: handoff allows "Supabase Auth (or clean auth abstraction)". We implement the
// abstraction with email OTP (backlog T1.1) which needs OTP + session persistence.
// These tables are auth-infrastructure only; swapping to Supabase removes them without
// touching any scoped business table.

model AuthOtp {
  id        String   @id @default(uuid())
  email     String
  codeHash  String                    // never store the raw code
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  @@index([email, expiresAt])
  @@index([email, createdAt]) // H8: resend cooldown lookup (latest OTP per email)
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique         // never store the raw session token
  expiresAt  DateTime
  revokedAt  DateTime?
  ip         String?
  device     String?
  createdAt  DateTime @default(now())
  @@index([userId])
}

// Durable rate limiter (H5/H8). Serverless invocations don't share memory, so a
// per-process token bucket resets every cold start and never trips; this
// Postgres-backed fixed-window counter survives the boundary. The increment is a
// single atomic upsert (see consumeRateLimit) so concurrent hits on one key
// can't race — the same TOCTOU class H4 fixed for secure links.
model RateLimit {
  key         String   @id           // e.g. "proof:<linkId>:<ip>" or "otp:<email>"
  windowStart DateTime @default(now())
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}
