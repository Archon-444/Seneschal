# PostgreSQL
DATABASE_URL="postgresql://seneschal:seneschal@localhost:5432/seneschal"

# Base URL used in emails and secure links
APP_BASE_URL="http://localhost:3000"

# Secret for session cookies and signed storage URLs (generate: openssl rand -hex 32)
APP_SECRET="dev-secret-change-me"

# Email gateway: "console" logs to stdout, "resend" sends via Resend
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
EMAIL_FROM="Seneschal <noreply@example.com>"

# Object storage: "local" writes under .storage/ — private, served only via signed URLs
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR=".storage"

# Extraction (OCR) provider: "mock" replays recorded outputs from fixtures; "anthropic" uses LLM vision
EXTRACTION_PROVIDER="mock"
ANTHROPIC_API_KEY=""

# Serverless deploy (Vercel)
# STORAGE_DRIVER=blob with BLOB_READ_WRITE_TOKEN (from the attached Blob store).
# Blob URLs are unguessable and live only in Document.storageKey — downloads
# still go exclusively through the signed /api/v1/files route.
BLOB_READ_WRITE_TOKEN=""

# Shared secret for the cron job route /api/v1/jobs/run (Vercel sends it as
# "Authorization: Bearer <CRON_SECRET>"). Generate: openssl rand -hex 32
CRON_SECRET=""
